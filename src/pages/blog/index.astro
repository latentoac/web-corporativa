---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSections from "../../components/sections/HeroSections.astro";
import { Image } from "astro:assets";

const posts = await getCollection("blog");
const sorted = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

/* const [featured, ...rest] = sorted; */
---

<BaseLayout>
  <HeroSections
    titular="Blog"
    subtitular="Ideas, procesos y novedades del espacio Latento"
  />

  <section class="blog-list">
    <div class="blog-list__container">
    
    <!-- ── GRID DE POSTS RESTANTES ── -->
    {
      sorted.length > 0 && (
        <div class="blog-list__content-wrapper">
          <div class="blog-list__section-header">
            <h2 class="blog-list__section-title">Todos los artículos</h2>
            <span class="blog-list__count">{posts.length} artículos</span>

          </div>

          <ul class="blog-list__grid">
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.id}`} class="post-card">
                  <div class="post-card__image-wrap">
                    {post.data.image ? (
                      <Image
                        src={post.data.image}
                        alt={post.data.title}
                        width={1066}
                        height={340}
                        format="webp"
                        quality={82}
                        loading="eager"
                      />
                    ) : (
                      <div
                        class="post-card__image-placeholder"
                        aria-hidden="true"
                      >
                        <svg
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                        >
                          <rect x="3" y="3" width="18" height="18" rx="2" />
                          <path d="m3 15 5-5 4 4 3-3 6 6" />
                        </svg>
                      </div>
                    )}
                  </div>
                  <div class="post-card__body">
                    <h3 class="post-card__title">{post.data.title}</h3>
                    <div class="post-card__spacer" />
                    <div class="post-card__meta">
                      <time
                        class="post-card__date"
                        datetime={post.data.date.toISOString()}
                      >
                        {post.data.date.toLocaleDateString("es-ES", {
                          day: "numeric",
                          month: "short",
                          year: "numeric",
                        })}
                      </time>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- ── ESTADO VACÍO ── -->
    {
      sorted.length === 0 && (
        <div class="blog-list__empty">
          <svg
            class="blog-list__empty-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
          <h3>Aún no hay artículos</h3>
          <p>
            Pronto publicaremos ideas, procesos y novedades del espacio Latento.
          </p>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  /* ============================================================
   BLOG INDEX — Listado de artículos
   Compatible con global.css de Latento
   Componentes: .blog-list, .blog-list__grid, .post-card
   ============================================================ */

  :root {
    --blog-index-width: 1100px;
    --blog-card-accent: var(--color-darktourquise);
    --blog-card-border: color-mix(
      in srgb,
      var(--color-marino) 10%,
      var(--color-light) 90%
    );
    --blog-card-radius: var(--radius-lg);
  }

  /* ─────────────────────────────────────────
   SECCIÓN CONTENEDORA
  ───────────────────────────────────────── */
  .blog-list {
    max-width: var(--blog-index-width);
    margin-inline: auto;
    padding-block: clamp(var(--space-8), 6vw, var(--space-16));
    padding-inline: var(--space-4);
  }

  .blog-list__container {
    display: block;
    width: 100%;
  }

  /* ─────────────────────────────────────────
   CABECERA DEL LISTADO
  ───────────────────────────────────────── */
  .blog-list__section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--blog-card-border);
  }

  .blog-list__section-title {
    font-family: var(--font-family-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
  }

  .blog-list__count {
    font-size: var(--text-sm);
    color: var(--color-gray);
    white-space: nowrap;
  }

  /* ─────────────────────────────────────────
   GRID DE CARDS
  ───────────────────────────────────────── */
  .blog-list__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: var(--space-6);
  }

  /* ─────────────────────────────────────────
   POST CARD — base
  ───────────────────────────────────────── */
  .post-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--blog-card-radius);
    overflow: hidden;
    border: 1px solid var(--blog-card-border);
    background-color: var(--color-light);
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 8px
      color-mix(in srgb, var(--color-marino) 6%, transparent 94%);
    transition:
      box-shadow var(--transition-interactive),
      transform var(--transition-interactive);
  }

  .post-card:hover,
  .post-card:focus-visible {
    box-shadow: 0 6px 24px
      color-mix(in srgb, var(--color-marino) 12%, transparent 88%);
    transform: translateY(-2px);
  }

  /* Imagen */
  .post-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background-color: var(--blog-card-border);
  }

  .post-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .post-card__image-wrap img {
    transform: scale(1.04);
  }

  /* Placeholder sin imagen */
  .post-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray);
  }

  .post-card__image-placeholder svg {
    width: 32px;
    height: 32px;
    opacity: 0.4;
  }

  /* Cuerpo */
  .post-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-5);
    gap: var(--space-3);
  }

  .post-card__title {
    font-family: var(--font-family-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    line-height: 1.25;
    color: var(--color-marino);
    text-wrap: balance;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-interactive);
  }

  .post-card:hover .post-card__title {
    color: var(--blog-card-accent);
  }

  /* Spacer empuja la meta al fondo de la card */
  .post-card__spacer {
    flex: 1;
  }

  /* Meta (fecha) */
  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .post-card__date {
    font-size: var(--text-sm);
    color: var(--color-gray);
  }

  /* ─────────────────────────────────────────
   ESTADO VACÍO
  ───────────────────────────────────────── */
  .blog-list__empty {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-16) var(--space-8);
    color: var(--color-gray);
  }

  .blog-list__empty-icon {
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
    opacity: 0.3;
    color: var(--color-darktourquise);
  }

  .blog-list__empty h3 {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-marino);
    margin-bottom: var(--space-2);
  }

  .blog-list__empty p {
    font-size: var(--text-base);
    max-width: 36ch;
  }

  /* ─────────────────────────────────────────
   RESPONSIVE
  ───────────────────────────────────────── */
  @media (max-width: 600px) {
    .post-card__body {
      padding: var(--space-6);
    }

    .blog-list__grid {
      gap: var(--space-4);
    }

    .blog-list__section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
  }
</style>
