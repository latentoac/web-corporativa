---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSections from "../../components/sections/HeroSections.astro";
import { Image } from 'astro:assets';


// Solo publicados, todos — el filtro lo hace el cliente
const allTalleres = await getCollection("talleres", ({ data }) => data.publicado);

const sorted = allTalleres.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const filtros = [
  { slug: "todos",    label: "Todos" },
  { slug: "santiago", label: "Talleres en Santiago" },
  { slug: "coruna",   label: "Talleres en A Coruña" },
  { slug: "online",   label: "Formación Online" },
];
---


<BaseLayout>
  <HeroSections
    titular="Talleres"
    subtitular="Descubre nuestras propuestas formativas y creativas"
  />

  <section class="talleres-section">
    <div class="talleres-container">

      <nav class="talleres-filtros" aria-label="Filtrar talleres por modalidad">
        {filtros.map((f) => (
          <button
            class="filtro-btn"
            data-filtro={f.slug}
            aria-pressed="false"
            type="button"
          >
            {f.label}
          </button>
        ))}
      </nav>

      {sorted.length === 0 ? (
        <div class="talleres-list__empty">
          <svg class="talleres-list__empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
          <h3>Próximamente nuevos talleres. ¡Vuelve pronto!</h3>
          <p>Pronto publicaremos nuevos talleres en Latento.</p>
        </div>
      ) : (
        <div>
          <ul class="talleres-grid" role="list" id="talleres-grid">
            {sorted.map((taller) => (
              <li
                class="taller-card"
                data-modalidad={taller.data.modalidad}
              >
                <!-- 1. NUEVA SECCIÓN: Imagen del taller -->
      {taller.data.image && (
         <div class="taller-card__image-wrapper">

    <Image
      src={taller.data.image}
      alt={taller.data.title}
      width={600}
      height={337}
      format="webp"
      quality={82}
      loading="eager"
      class="taller-card__image"
    />

    <!-- 2. NUEVA SECCIÓN: Pill de modalidad -->
    <span class="taller-card__badge">
      {taller.data.modalidad}
    </span>
  </div>
)}
                <div class="taller-card__body">
                  <time
                    class="taller-card__date"
                    datetime={taller.data.date.toISOString()}
                  >
                    {taller.data.date.toLocaleDateString("es-ES", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    })}
                  </time>
                  <h2 class="taller-card__title">
                    <a class="taller-card__title-link" href={`/talleres/${taller.id}`}>
                      {taller.data.title}
                    </a>
                  </h2>
                  {taller.data.description && (
                    <p class="taller-card__desc">{taller.data.description}</p>
                  )}
                </div>
                <footer class="taller-card__footer">
                  <a class="taller-card__link" href={`/talleres/${taller.id}`}>
                    Ver taller
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                  </a>
                  {taller.data.inscription_url && (
                    <a
                      class="taller-card__cta"
                      href={taller.data.inscription_url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Inscríbete
                    </a>
                  )}
                </footer>
              </li>
            ))}
          </ul>
        </div>
      )}

    </div>
  </section>
</BaseLayout>


<style>
  /* ── Filtros ───────────────────────────────────────────── */
  .talleres-filtros {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .filtro-btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-family: var(--font-family-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    color: var(--color-marino);
    background-color: transparent;
    border: 1px solid rgba(35, 42, 52, 0.2);
    transition:
      background-color var(--transition-interactive),
      color var(--transition-interactive),
      border-color var(--transition-interactive);
    min-height: 44px;
  }

  .filtro-btn:hover,
  .filtro-btn:focus-visible {
    background-color: rgba(35, 42, 52, 0.06);
    border-color: var(--color-marino);
  }

  .filtro-btn--activo {
    background-color: var(--color-magenta);
    color: var(--color-light);
    border-color: var(--color-magenta);
  }

  .filtro-btn--activo:hover,
  .filtro-btn--activo:focus-visible {
    background-color: var(--color-darktourquise);
    border-color: var(--color-darktourquise);
  }

  /* ── Sección ───────────────────────────────────────────── */
  .talleres-section {
    padding-block: clamp(var(--space-10), 6vw, var(--space-16));
  }

  .talleres-container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  /* ── Grid de tarjetas ──────────────────────────────────── */
  .talleres-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Tarjeta individual ────────────────────────────────── */
  .taller-card {
    background-color: var(--color-light);
    border: 1px solid rgba(35, 42, 52, 0.1); /* --color-marino con alpha */
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow:
      0 1px 3px rgba(44, 63, 68, 0.06),
      0 4px 12px rgba(44, 63, 68, 0.04);
    transition:
      box-shadow var(--transition-interactive),
      transform var(--transition-interactive);
  }

  .taller-card:hover {
    box-shadow:
      0 4px 16px rgba(44, 63, 68, 0.1),
      0 12px 32px rgba(44, 63, 68, 0.08);
    transform: translateY(-2px);
  }

  /* ── Tarjeta individual (Actualización) ── */
.taller-card {
  background-color: var(--color-light);
  border: 1px solid rgba(35, 42, 52, 0.1);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  /* Eliminamos justify-content: space-between para que la imagen mande */
  overflow: hidden; /* Importante para que la imagen respete el border-radius */
  box-shadow: 0 1px 3px rgba(4, 63, 68, 0.06), 0 4px 12px rgba(44, 63, 68, 0.04);
  transition: box-shadow var(--transition-interactive), transform var(--transition-interactive);
}

/* ── Nuevo: Contenedor de Imagen y Badge ── */
.taller-card__image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
}

.taller-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover; /* Evita que la imagen se deforme */
  transition: transform var(--transition-interactive);
}

.taller-card:hover .taller-card__image {
  transform: scale(1.05); /* Efecto zoom suave al pasar el mouse */
}

/* ── Nuevo: Pill de Modalidad (Badge) ── */
.taller-card__badge {
  position: absolute;
  top: var(--space-4);
  left: var(--space-4);
  padding: 5px 8px;
  background-color: rgba(255, 255, 255, 0.9); /* Fondo blanco semi-transparente */
  backdrop-filter: blur(4px); /* Efecto cristal moderno */
  color: var(--color-marino);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-bold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-radius: var(--radius-full);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  pointer-events: none;
}

  /* ── Cuerpo ────────────────────────────────────────────── */
  .taller-card__body {
    padding: var(--space-6);
    flex: 1;
  }

  .taller-card__date {
    display: block;
    font-family: var(--font-family-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-darktourquise);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }

  .taller-card__title {
    font-family: var(--font-family-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-marino);
    line-height: 1.2;
    margin-bottom: var(--space-3);
    text-wrap: balance;
  }

  .taller-card__title-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-interactive);
  }

  .taller-card__title-link:hover,
  .taller-card__title-link:focus-visible {
    color: var(--color-darktourquise);
  }

  .taller-card__desc {
    font-family: var(--font-family-body);
    font-size: var(--text-base);
    color: var(--color-gray);
    line-height: 1.6;
    max-width: 60ch;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer de la tarjeta ──────────────────────────────── */
  .taller-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid rgba(35, 42, 52, 0.08);
  }

  /* Enlace secundario "Ver taller" */
  .taller-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-family-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-darktourquise);
    text-decoration: none;
    transition:
      color var(--transition-interactive),
      gap var(--transition-interactive);
  }

  .taller-card__link:hover,
  .taller-card__link:focus-visible {
    color: var(--color-texto-dark);
    gap: var(--space-3);
  }

  /* Botón primario "Inscríbete" */
  .taller-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-5);
    background-color: var(--color-magenta);
    color: var(--color-light);
    font-family: var(--font-family-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition:
      background-color var(--transition-interactive),
      transform var(--transition-interactive);
    white-space: nowrap;
    min-height: 44px;
  }

  .taller-card__cta:hover,
  .taller-card__cta:focus-visible {
    background-color: var(--color-darktourquise);
    transform: translateY(-1px);
  }

  /* ── Estado vacío ──────────────────────────────────────── */
.talleres-list__empty {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-16) var(--space-8);
  color: var(--color-gray);
}

.talleres-list__empty-icon {
  width: 48px;
  height: 48px;
  margin-bottom: var(--space-4);
  opacity: 0.3;
  color: var(--color-darktourquise);
}

.talleres-list__empty h3 {
  font-size: var(--text-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-marino);
  margin-bottom: var(--space-2);
}

.talleres-list__empty p {
  font-size: var(--text-base);
  max-width: 36ch;
}

.taller-card[hidden] {
  display: none !important;
}

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 640px) {
    .talleres-container {
      padding-inline: var(--space-4);
    }

    .taller-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
