---
import { Image } from "astro:assets";
import HeroSections from "../components/sections/HeroSections.astro";
import bannerIebt from "../assets/brand/partners/cartel_iebt.avif";
import bannerBono from "../assets/brand/partners/cartel-programa-bono.avif";
import BaseLayout from "../layouts/BaseLayout.astro";

const partners = [
  { nombre: "Xunta de Galicia", banner: bannerIebt },
  { nombre: "Xunta de Galicia", banner: bannerBono },
];
---
<BaseLayout>
<section class="colaboradores">
  <HeroSections
    titular="Colaboradores"
    subtitular="Conoce las entidades que han brindado su apoyo a nuestra empresa. Gracias a su colaboración, seguimos creciendo y innovando cada día."
  />

  <div class="colaboradores__container">
    {
      partners.map((partner) => (
        <Image
              class="colaboradores__img"
              src={partner.banner}
              alt={partner.nombre}
              widths={[320, 480, 640, 800]}
              sizes="(max-width: 767px) 100vw, (max-width: 1200px) 50vw, 600px"
              loading="lazy"
              decoding="async"
            />
      ))
    }
  </div>
</section>
</BaseLayout>

<style>
  .colaboradores {
    padding-block: clamp(2rem, 4vw, 4rem);
  }

  .colaboradores__container {
    width: min(100%, 1200px);
    margin-inline: auto;
    padding-inline: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .colaboradores__card {
    margin: 0;
    border-radius: 1rem;
    overflow: hidden;
  }

  .colaboradores__img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 1rem;
  }

  @media (min-width: 768px) {
    .colaboradores__container {
      gap: 1.5rem;
      padding-inline: 1.5rem;
    }
  }

</style>