---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import NewsletterModal from '../components/sections/NewsletterModal.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Latento Altas Capacidades",
  description = "Somos un equipo multidisciplinar de expertas en identificación, orientación e intervención de altas capacidades.",
  canonical = "https://www.latentoac.com/",
  ogImage = "https://www.latentoac.com/logo_latento_final-01.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
      <meta name="theme-color" content="#CE3061">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <meta
      name="google-site-verification"
      content="NggZeWxBR3wp2o9HkWNEvukTgyts5MKrZWXlRpKn5i0"
    />
    <link rel="canonical" href={canonical} />
    <link rel="shortlink" href={canonical} />

    <meta property="og:locale" content="es_ES" />
    <meta
      property="og:site_name"
      content="Latento - Servicio Integral Altas Capacidades"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1269" />
    <meta property="og:image:height" content="1340" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
	<Header/>
	<main>
		<slot />
	</main>
	<Footer/>
  <NewsletterModal/>

<script>
 const btnsFiltro = document.querySelectorAll<HTMLButtonElement>('.filtro-btn');
  const cards = document.querySelectorAll<HTMLElement>('.taller-card');

  btnsFiltro.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filtro = btn.dataset.filtro;

      btnsFiltro.forEach((b) => {
        b.classList.remove('filtro-btn--activo');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('filtro-btn--activo');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach((card) => {
        const modalidades = JSON.parse(card.dataset.modalidad ?? '[]');
        const visible = filtro === 'todos' || modalidades.includes(filtro);
        card.style.display = visible ? '' : 'none';
      });
    });
  });

/* Lee la URL del parámetro de modalidad al pulsar un ButtonCTA */
  const params = new URLSearchParams(window.location.search);
  const modalidadParam = params.get('modalidad');

  if (modalidadParam) {
    const btnObjetivo = document.querySelector<HTMLButtonElement>(
      `[data-filtro="${modalidadParam}"]`
    );
    btnObjetivo?.click();
  } else {
    document.querySelector<HTMLButtonElement>('[data-filtro="todos"]')?.click();
  }
</script>
  </body>
</html>
