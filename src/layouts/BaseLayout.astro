---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import NewsletterModal from '../components/sections/NewsletterModal.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Latento Altas Capacidades",
  description = "Somos un equipo multidisciplinar de expertas en identificación, orientación e intervención de altas capacidades.",
  canonical = "https://www.latentoac.com/",
  ogImage = "https://www.latentoac.com/logo_latento_final-01.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <meta
      name="google-site-verification"
      content="NggZeWxBR3wp2o9HkWNEvukTgyts5MKrZWXlRpKn5i0"
    />
    <link rel="canonical" href={canonical} />
    <link rel="shortlink" href={canonical} />

    <meta property="og:locale" content="es_ES" />
    <meta
      property="og:site_name"
      content="Latento - Servicio Integral Altas Capacidades"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1269" />
    <meta property="og:image:height" content="1340" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
	<Header/>
	<main>
		<slot />
	</main>
	<Footer/>
  <NewsletterModal/>

  <script>
  const params = new URLSearchParams(window.location.search);
  const modalidadInicial = params.get("modalidad") ?? "todos";

  const botones = document.querySelectorAll<HTMLButtonElement>(".filtro-btn");
  const tarjetas = document.querySelectorAll<HTMLLIElement>(".taller-card");
  const mensajeVacio = document.getElementById("filtro-vacio");

  function aplicarFiltro(modalidad: string) {
    let visibles = 0;

    tarjetas.forEach((card) => {
      const coincide =
        modalidad === "todos" || card.dataset.modalidad === modalidad;
      card.hidden = !coincide;
      if (coincide) visibles++;
    });

    // Mostrar mensaje vacío si no hay resultados para ese filtro
    if (mensajeVacio) mensajeVacio.hidden = visibles > 0;

    // Actualizar aria-pressed y clase activa
    botones.forEach((btn) => {
      const activo = btn.dataset.filtro === modalidad;
      btn.setAttribute("aria-pressed", String(activo));
      btn.classList.toggle("filtro-btn--activo", activo);
    });

    // Actualizar la URL sin recargar la página
    const url = new URL(window.location.href);
    if (modalidad === "todos") {
      url.searchParams.delete("modalidad");
    } else {
      url.searchParams.set("modalidad", modalidad);
    }
    history.replaceState(null, "", url.toString());
  }

  // Activar filtro inicial (viene de la home o de un enlace directo)
  aplicarFiltro(modalidadInicial);

  // Click en cada botón
  botones.forEach((btn) => {
    btn.addEventListener("click", () => {
      aplicarFiltro(btn.dataset.filtro ?? "todos");
    });
  });
</script>
  </body>
</html>
