---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import NewsletterModal from '../components/sections/NewsletterModal.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Latento Altas Capacidades",
  description = "Somos un equipo multidisciplinar de expertas en identificación, orientación e intervención de altas capacidades.",
  canonical = "https://www.latentoac.com/",
  ogImage = "https://www.latentoac.com/logo_latento_final-01.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <meta
      name="google-site-verification"
      content="NggZeWxBR3wp2o9HkWNEvukTgyts5MKrZWXlRpKn5i0"
    />
    <link rel="canonical" href={canonical} />
    <link rel="shortlink" href={canonical} />

    <meta property="og:locale" content="es_ES" />
    <meta
      property="og:site_name"
      content="Latento - Servicio Integral Altas Capacidades"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1269" />
    <meta property="og:image:height" content="1340" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
	<Header/>
	<main>
		<slot />
	</main>
	<Footer/>
  <NewsletterModal/>

  <script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btns = document.querySelectorAll(".filtro-btn");
    const cards = document.querySelectorAll(".taller-card");
    const filtroVacio = document.getElementById("filtro-vacio");

    console.log("Botones encontrados:", btns.length);
    console.log("Tarjetas encontradas:", cards.length);
    console.log("Elemento filtro-vacio:", filtroVacio);

    const btnTodos = document.querySelector('[data-filtro="todos"]');
    if (btnTodos) {
      btnTodos.classList.add("filtro-btn--activo");
      btnTodos.setAttribute("aria-pressed", "true");
    }

    function aplicarFiltro(filtro) {
      let visibles = 0;

      cards.forEach((card) => {
        const modalidad = card.dataset.modalidad ?? "";
        const mostrar = filtro === "todos" || modalidad === filtro;
        card.hidden = !mostrar;
        if (mostrar) visibles++;
      });

      if (filtroVacio) {
        filtroVacio.hidden = visibles > 0;
      }

      btns.forEach((btn) => {
        const activo = btn.dataset.filtro === filtro;
        btn.classList.toggle("filtro-btn--activo", activo);
        btn.setAttribute("aria-pressed", activo ? "true" : "false");
      });
    }

    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filtro = btn.dataset.filtro ?? "todos";
        aplicarFiltro(filtro);
      });
    });
  });
</script>
  </body>
</html>
