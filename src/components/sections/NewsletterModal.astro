---
// src/components/NewsletterModal.astro
// No necesita props — la URL del form viene del código de MailChimp
---

<div
  id="newsletter-modal"
  class="nl-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Boletín de novedades"
  hidden
>
  <div class="nl-modal__backdrop" id="nl-backdrop"></div>

  <div class="nl-modal__box">
    <button class="nl-modal__close" id="nl-close" aria-label="Cerrar">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M3 3l10 10M13 3L3 13"></path>
      </svg>
    </button>

    <p class="nl-modal__eyebrow">Latento AC</p>
    <h2 class="nl-modal__title">Boletín de novedades</h2>
    <p class="nl-modal__sub">
      Recibe en tu correo las últimas novedades, talleres y recursos sobre altas
      capacidades.
    </p>

    <!-- ✅ PEGA AQUÍ EL FORMULARIO DE MAILCHIMP
         ⚠️  Elimina la línea <link href="//cdn-images..."> que viene arriba
         ⚠️  Elimina el <h2>Subscribe</h2> que viene dentro
         ⚠️  Mantén el campo honeypot (el div con position:absolute)       -->
    <div id="mc_embed_signup">
    <form action="https://latentoac.us19.list-manage.com/subscribe/post?u=1e84dc563de5bb8edbbb5bdd0&amp;id=4284b03ae0&amp;f_id=00bbdce6f0" method="post" id="mc-embedded-subscribe-form" name="mc-embedded-subscribe-form" class="validate" target="_blank">
        <div id="mc_embed_signup_scroll"><h2>Suscríbete a nuestro boletín de novedades</h2>
            <div class="indicates-required"><span class="asterisk">*</span> indica que es obligatorio</div>
            <div class="mc-field-group"><label for="mce-EMAIL">Email Address <span class="asterisk">*</span></label><input type="email" name="EMAIL" class="required email" id="mce-EMAIL" required="" value=""><span id="mce-EMAIL-HELPERTEXT" class="helper_text">Escribe tu correo electrónico aquí.</span></div>
        <div id="mce-responses" class="clear foot">
            <div class="response" id="mce-error-response" style="display: none;"></div>
            <div class="response" id="mce-success-response" style="display: none;"></div>
        </div>
    <div aria-hidden="true" style="position: absolute; left: -5000px;">
        /* real people should not fill this in and expect good things - do not remove this or risk form bot signups */
        <input type="text" name="b_1e84dc563de5bb8edbbb5bdd0_4284b03ae0" tabindex="-1" value="">
    </div>
        <div class="optionalParent">
            <div class="clear foot">
                <input type="submit" name="subscribe" id="mc-embedded-subscribe" class="button" value="Subscribe">
                <p style="margin: 0px auto;"><a href="http://eepurl.com/jD8Jrw" title="Mailchimp: marketing por correo electrónico fácil y divertido"><span style="display: inline-block; background-color: transparent; border-radius: 4px;"><img class="refferal_badge" src="https://digitalasset.intuit.com/render/content/dam/intuit/mc-fe/en_us/images/intuit-mc-rewards-text-dark.svg" alt="Intuit Mailchimp" style="width: 220px; height: 40px; display: flex; padding: 2px 0px; justify-content: center; align-items: center;"></span></a></p>
            </div>
        </div>
    </div>
        <!-- <div id="mc_embed_signup_scroll">
          <div class="mc-field-group">
            <label for="mce-EMAIL"
              >Correo electrónico <span class="asterisk">*</span></label
            >
            <input
              type="email"
              name="EMAIL"
              class="required email"
              id="mce-EMAIL"
              placeholder="tu@correo.com"
              required
            />
          </div>
 -->
          <!-- Honeypot anti-spam — NO tocar -->
          <div style="position:absolute;left:-5000px;" aria-hidden="true">
            <input
              type="text"
              name="b_XXXXXXXX_YYYYYYYY"
              tabindex="-1"
              value=""
            />
          </div>

<!--           <div class="nl-submit-wrap">
            <input
              type="submit"
              value="Suscribirme"
              name="subscribe"
              id="mc-embedded-subscribe"
              class="nl-submit"
            />
          </div> -->
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("newsletter-modal");
  const backdrop = document.getElementById("nl-backdrop");
  const closeBtn = document.getElementById("nl-close");

  window.openNewsletterModal = () => {
    modal.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  };

  const closeModal = () => {
    modal.setAttribute("hidden", "");
    document.body.style.overflow = "";
  };

  backdrop.addEventListener("click", closeModal);
  closeBtn.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<style>
  /* ── Modal estructura ── */
  .nl-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }
  .nl-modal[hidden] {
    display: none;
  }

  .nl-modal__backdrop {
    position: absolute;
    inset: 0;
    background: oklch(0.15 0.02 220 / 0.55);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .nl-modal__box {
    position: relative;
    background: var(--color-light);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    width: 100%;
    max-width: 460px;
    box-shadow: 0 24px 64px oklch(0.1 0.02 220 / 0.22);
  }

  /* ── Botón cerrar ── */
  .nl-modal__close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    color: var(--color-gray);
    transition:
      background var(--transition-interactive),
      color var(--transition-interactive);
  }
  .nl-modal__close:hover {
    background: var(--color-light-dark);
    color: var(--color-texto-dark);
  }
  .nl-modal__close svg {
    width: 16px;
    height: 16px;
  }

  /* ── Copy ── */
  .nl-modal__eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-magenta);
    margin-bottom: 0.25rem;
  }
  .nl-modal__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-texto-dark);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .nl-modal__sub {
    font-size: var(--text-sm);
    color: var(--color-gray);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  /* ── Formulario MailChimp (override de estilos) ── */
  #mc_embed_signup {
    all: unset;
    display: block;
  }
  #mc_embed_signup_scroll {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mc-field-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .mc-field-group label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-texto-dark);
  }
  .mc-field-group .asterisk {
    color: var(--color-magenta);
    margin-left: 2px;
  }

  .mc-field-group input[type="email"] {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 1.5px solid #ddd;
    border-radius: var(--radius-md);
    font-family: var(--font-family-body);
    font-size: var(--text-base);
    color: var(--color-texto-dark);
    background: var(--color-light);
    transition:
      border-color var(--transition-interactive),
      box-shadow var(--transition-interactive);
  }
  .mc-field-group input[type="email"]::placeholder {
    color: #aaa;
  }
  .mc-field-group input[type="email"]:focus-visible {
    outline: none;
    border-color: var(--color-magenta);
    box-shadow: 0 0 0 3px rgba(206, 48, 97, 0.15);
  }

  /* ── Botón submit ── */
  .nl-submit-wrap {
    margin-top: var(--space-2);
  }
  .nl-submit {
    width: 100%;
    padding: 0.8rem 1rem;
    background: var(--color-magenta);
    color: var(--color-light);
    font-family: var(--font-family-body);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition:
      background var(--transition-interactive),
      transform var(--transition-interactive),
      box-shadow var(--transition-interactive);
  }
  .nl-submit:hover {
    background: #a82350;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(206, 48, 97, 0.3);
  }
  .nl-submit:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .nl-modal__box {
      padding: var(--space-6);
    }
    .nl-modal__title {
      font-size: var(--text-lg);
    }
  }
</style>
