<div
  id="newsletter-modal"
  class="nl-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Boletín de novedades"
  hidden
>
  <div class="nl-modal__backdrop" id="nl-backdrop"></div>

  <div class="nl-modal__box">
    <button class="nl-modal__close" id="nl-close" aria-label="Cerrar">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M3 3l10 10M13 3L3 13"></path>
      </svg>
    </button>

    <p class="nl-modal__eyebrow">Latento AC</p>
    <h2 class="nl-modal__title">Boletín de novedades</h2>
    <p class="nl-modal__sub">
      Recibe en tu correo las últimas novedades, talleres y recursos sobre altas
      capacidades.
    </p>

    <div id="nl-form-content">
      <div id="mc_embed_signup">
        <form
          action="https://latentoac.us19.list-manage.com/subscribe/post?u=1e84dc563de5bb8edbbb5bdd0&id=4284b03ae0&f_id=00bbdce6f0"
          method="post"
          id="mc-embedded-subscribe-form"
          name="mc-embedded-subscribe-form"
          class="validate"
        >
          <div id="mc_embed_signup_scroll">
            <div class="mc-field-group">
              <label for="mce-EMAIL">
                Correo electrónico <span class="asterisk">*</span>
              </label>
              <input
                type="email"
                name="EMAIL"
                class="required email"
                id="mce-EMAIL"
                placeholder="tu@correo.com"
                required
                value=""
              />
            </div>

            <div aria-hidden="true" style="position: absolute; left: -5000px;">
              <!-- real people should not fill this in -->
              <input
                type="text"
                name="b_1e84dc563de5bb8edbbb5bdd0_4284b03ae0"
                tabindex="-1"
                value=""
              />
            </div>

            <div class="optionalParent">
              <div class="clear foot">
                <input
                  type="submit"
                  name="subscribe"
                  id="mc-embedded-subscribe"
                  class="button nl-submit"
                  value="Suscribirme"
                />
              </div>
            </div>
          </div>
        </form>
      </div>

      <!-- Error inline -->
      <p id="nl-error" hidden class="nl-error-msg"></p>
    </div>

    <!-- Éxito — fuera del nl-form-content para que no se oculte junto al form -->
    <div id="nl-success" hidden class="nl-success">
      <svg
        viewBox="0 0 48 48"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="24" cy="24" r="20"></circle>
        <path d="M15 24l7 7 11-14"></path>
      </svg>
      <h3>¡Ya estás suscrita/o!</h3>
      <p>Pronto recibirás las novedades de Latento AC en tu correo.</p>
      <button
        onclick="document.getElementById('nl-close').click()"
        class="nl-submit"
        style="margin-top:1rem"
      >
        Cerrar
      </button>
    </div>
  </div>
</div>

<script is:inline>
  window.openNewsletterModal = () => {
    const form = document.getElementById("mc-embedded-subscribe-form");
    const modal = document.getElementById("newsletter-modal");
    const closeBtn = document.getElementById("nl-close");

    document.getElementById("nl-success").setAttribute("hidden", "");
    document.getElementById("nl-form-content").removeAttribute("hidden");
    const errorEl = document.getElementById("nl-error");
    errorEl.setAttribute("hidden", "");
    errorEl.textContent = "";
    form.reset();

    modal.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  };

  document.addEventListener("click", (e) => {
    if (e.target.id === "nl-backdrop" || e.target.id === "nl-close" || e.target.closest("#nl-close")) {
      closeNewsletterModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeNewsletterModal();
  });

  window.closeNewsletterModal = () => {
    const form = document.getElementById("mc-embedded-subscribe-form");
    const modal = document.getElementById("newsletter-modal");

    modal.setAttribute("hidden", "");
    document.body.style.overflow = "";
    document.getElementById("nl-success").setAttribute("hidden", "");
    document.getElementById("nl-form-content").removeAttribute("hidden");
    const errorEl = document.getElementById("nl-error");
    errorEl.setAttribute("hidden", "");
    errorEl.textContent = "";
    form.reset();
  };
</script>


