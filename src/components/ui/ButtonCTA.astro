---

interface Props {
  href: string;
  label: string;
  icon: string;
  alt: string;
  workshop: string;
  alt2: string;
  color: string;
}


const { href, label, icon, alt, workshop, alt2, color } = Astro.props;
---

<a class="button-cta" href={href} aria-label={label}>
  <img class="button-cta__icon" src={icon} alt={alt} width="60" height="60" loading="lazy" />
  <img class="button-cta__workshop" src={workshop} alt={alt2} loading="lazy" />
</a>

<style define:vars={{ cardColor: color }}>
  .button-cta {
    border: 1px solid var(--color-gray-poor);
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background-color: var(--color-light);
    text-decoration: none;
    transition:
      border-color var(--transition-interactive),
      transform var(--transition-interactive),
      box-shadow var(--transition-interactive);
  }

  .button-cta:hover,
  .button-cta:focus-visible {
    border-color: var(--cardColor);
    transform: scale(1.03);
    box-shadow: 0 8px 24px oklch(0.2 0.01 80 / 0.08);
  }

  .button-cta__icon {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
  }

  @media (max-width: 550px) {
    .button-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
