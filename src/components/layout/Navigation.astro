---
interface Props {
  isMobile?: boolean;
}

const { isMobile = false } = Astro.props;

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/#about", label: "Quiénes somos" },
  { href: "/#what", label: "Qué hacemos" },
  { href: "/#services", label: "Servicios" },
  { href: "/talleres", label: "Talleres" },
  { href: "/#contact", label: "Infórmate" },
  { href: "/recursos-humanos", label: "RR.HH." },
  { href: "/blog", label: "Blog" },
];

const currentPath = Astro.url.pathname;
---

<nav aria-label={isMobile ? "Principal móvil" : "Principal"}>
  <ul class:list={["site-header__nav-list", isMobile && "site-header__nav-list--mobile"]}>
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="site-header__nav-link"
            aria-current={currentPath === item.href ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
