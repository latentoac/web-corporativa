{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "modalidad": {
      "type": "string",
      "enum": [
        "santiago",
        "coruna",
        "online"
      ]
    },
    "inscription_url": {
      "type": "string",
      "format": "uri"
    },
    "publicado": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "modalidad"
  ]
}