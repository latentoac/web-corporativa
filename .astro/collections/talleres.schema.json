{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "dirigido_a": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "hora_inicio": {
      "type": "string"
    },
    "hora_fin": {
      "type": "string"
    },
    "precio": {
      "type": "number"
    },
    "image": {
      "type": "string"
    },
    "modalidad": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "santiago",
          "coruna",
          "online"
        ]
      }
    },
    "inscription_url": {
      "type": "string",
      "format": "uri"
    },
    "fecha_limite_inscripcion": {
      "type": "string",
      "format": "date-time"
    },
    "publicado": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "modalidad"
  ]
}